# Zero Auth Wallet - Environment Variables
# Copy this file to .env and fill in your values

# University/Student ID Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Aadhaar Supabase (optional - uses default if not set)
EXPO_PUBLIC_AADHAAR_SUPABASE_URL=https://your-aadhaar-project.supabase.co
EXPO_PUBLIC_AADHAAR_SUPABASE_ANON_KEY=your-aadhaar-anon-key

# Relay URL (optional - defaults to zeroauth-relay.onrender.com)
# EXPO_PUBLIC_RELAY_URL=https://your-relay.com
